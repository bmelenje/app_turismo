# Copia este archivo como .env y llena los valores reales
# NUNCA subas .env a Git

# URL base del backend
VITE_API_URL=http://localhost:4000

# IP de la cámara remota (para desarrollo local)
VITE_CAMERA_IP=http://192.168.1.50:8080
VITE_CAMERA_USER=admin
VITE_CAMERA_PASS=admin

# Estilo del mapa (MapLibre)
# Estilo vector tipo Google Maps: limpio, con calles y lugares etiquetados
VITE_MAP_STYLE=https://api.maptiler.com/maps/streets-v2/style.json?key=xPsUVws2pxrsmWzwvTJP
# Alternativas (misma key): descomenta la que prefieras
#VITE_MAP_STYLE=https://api.maptiler.com/maps/basic-v2/style.json?key=xPsUVws2pxrsmWzwvTJP
#VITE_MAP_STYLE=https://api.maptiler.com/maps/bright-v2/style.json?key=xPsUVws2pxrsmWzwvTJP
#VITE_MAP_STYLE=https://api.maptiler.com/maps/hybrid/style.json?key=xPsUVws2pxrsmWzwvTJP

# CouchDB para sincronización offline (opcional en MVP)
VITE_COUCHDB_URL=http://localhost:5984/parque-caldas

# Coordenadas del proyecto (flexibles para otro parque/ciudad)
VITE_MAP_CENTER_LNG=-76.6127
VITE_MAP_CENTER_LAT=2.4428
VITE_MAP_ZOOM=15

# Nombre del proyecto (aparece en la app)
VITE_APP_NAME=Parque Caldas
VITE_APP_CITY=Popayán

# Guía IA — API key de Groq (console.groq.com)
# OJO: al ser app de solo front, esta key queda visible en el bundle del navegador.
VITE_GROQ_API_KEY=tu_groq_api_key_aqui
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# Rutas a pie reales — OpenRouteService (perfil foot-walking).
# Gratis sin tarjeta: crea la key en https://openrouteservice.org/dev/#/signup
# Si la dejas vacía, la app usa OSRM (enruta como carro) corrigiendo el tiempo a pie.
VITE_ORS_API_KEY=
